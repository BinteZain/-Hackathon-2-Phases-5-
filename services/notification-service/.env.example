# Service Configuration
SERVICE_NAME=notification-service
APP_PORT=8082
DEBUG=false
LOG_LEVEL=INFO

# Database Configuration
DATABASE_HOST=postgresql.postgres.svc.cluster.local
DATABASE_PORT=5432
DATABASE_NAME=todo_chatbot
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres123

# Dapr Configuration
DAPR_HTTP_PORT=3500
DAPR_PUBSUB_NAME=pubsub-kafka
DAPR_STATE_STORE_NAME=state-redis

# Kafka Topics
KAFKA_TOPIC_REMINDERS=reminders
KAFKA_TOPIC_TASK_EVENTS=task-events

# Email Configuration (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@todo-chatbot.com
SMTP_FROM_NAME=Todo Chatbot
SMTP_USE_TLS=true

# Push Notification Configuration
FIREBASE_API_KEY=your-firebase-api-key
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apns-team-id
APNS_KEY_PATH=/app/secrets/apns.p8

# Notification Settings
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
BATCH_SIZE=100

# Redis Configuration (for Dapr state)
REDIS_HOST=redis-master.redis.svc.cluster.local
REDIS_PORT=6379
REDIS_PASSWORD=redis123
